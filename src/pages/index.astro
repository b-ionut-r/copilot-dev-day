<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Mona Mayhem</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style is:global>
      body {
        font-family: 'Press Start 2P', system-ui, sans-serif;
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
        text-align: center;
        background-color: #0a0a1a;
        color: #5fed83;
        box-sizing: border-box;
        position: relative;
        min-height: 100vh;
      }
      
      /* CRT scanline effect */
      body::after {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(
          rgba(18, 16, 16, 0) 50%,
          rgba(0, 0, 0, 0.03) 50%,
          rgba(0, 0, 0, 0.03) 100%
        );
        background-size: 100% 4px;
        pointer-events: none;
        z-index: 9999;
      }

      @keyframes neonPulse {
        0%, 100% { text-shadow: 0 0 5px #fff, 0 0 10px #fff, 0 0 20px #5fed83, 0 0 40px #5fed83, 0 0 80px #5fed83; }
        50% { text-shadow: 0 0 2px #fff, 0 0 5px #fff, 0 0 10px #5fed83, 0 0 20px #5fed83, 0 0 40px #5fed83; }
      }

      h1 {
        color: #fff;
        animation: neonPulse 3s infinite alternate;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
      }
      
      h2 {
        color: #8a2be2;
        font-size: 1rem;
        margin-bottom: 3rem;
        text-shadow: 0 0 5px #8a2be2;
      }

      .arena {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 2rem;
      }
      
      .player {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      @keyframes floatIn {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
      }

      .player:nth-child(1) {
        animation: floatIn 0.8s ease-out forwards;
      }
      
      .player:nth-child(2) {
        animation: floatIn 0.8s ease-out 0.3s forwards;
        opacity: 0; /* Starting state before animation */
      }

      input {
        padding: 0.75rem;
        font-size: 0.8rem;
        font-family: 'Press Start 2P', system-ui, sans-serif;
        margin-top: 1rem;
        border: 2px solid #5fed83;
        border-radius: 0;
        background-color: #000;
        color: #5fed83;
        outline: none;
        box-shadow: 0 0 10px rgba(95, 237, 131, 0.2);
        transition: box-shadow 0.3s;
      }
      
      input:focus {
        box-shadow: 0 0 15px rgba(95, 237, 131, 0.6);
      }

      button {
        padding: 1rem 2rem;
        font-size: 1rem;
        font-family: 'Press Start 2P', system-ui, sans-serif;
        background-color: transparent;
        color: #8a2be2;
        border: 2px solid #8a2be2;
        cursor: pointer;
        margin-bottom: 2rem;
        text-transform: uppercase;
        box-shadow: 0 0 10px rgba(138, 43, 226, 0.3), inset 0 0 10px rgba(138, 43, 226, 0.3);
        transition: all 0.3s;
        animation: floatIn 0.8s ease-out 0.6s forwards;
        opacity: 0;
      }
      
      button:hover {
        background-color: #8a2be2;
        color: #fff;
        box-shadow: 0 0 20px rgba(138, 43, 226, 0.8), inset 0 0 10px rgba(138, 43, 226, 0.8);
      }

      #results-area {
        padding: 1.5rem;
        border: 2px solid #5fed83;
        min-height: 100px;
        background: #111122;
        box-sizing: border-box;
        width: 100%;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
      }

      .results-grid {
        display: flex;
        flex-direction: column;
        justify-content: space-around;
        text-align: center;
        align-items: center;
        gap: 1rem;
      }
      
      @media (min-width: 600px) {
        .results-grid {
          flex-direction: row;
          align-items: flex-start;
        }
      }

      @keyframes shimmerSweep {
        0% { left: -150%; }
        100% { left: 150%; }
      }

      .player-result.graph-container {
        max-width: 100%;
        overflow-x: auto;
      }

      .player-result {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 45%;
        background: #1a1a2e;
        padding: 1rem;
        border: 1px solid #8a2be2;
        position: relative;
        overflow: hidden;
      }

      .player-result::before {
        content: "";
        position: absolute;
        top: 0;
        left: -150%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(95, 237, 131, 0.2) 50%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-25deg);
        animation: shimmerSweep 3s ease-in-out infinite;
        pointer-events: none;
      }

      .player-result h4 {
        margin: 0;
        font-size: 1rem;
        color: #fff;
        text-shadow: 0 0 5px #fff;
      }

      .player-score {
        font-size: 1.5rem;
        font-weight: bold;
        margin: 1rem 0;
        color: #5fed83;
      }

      .player-dates {
        font-size: 0.6rem;
        color: #aaa;
        margin-bottom: 1rem;
      }

      .graph {
        display: flex;
        gap: 2px;
        overflow-x: auto;
        padding: 1rem;
        background: #000;
        border: 1px solid #333;
        width: 100%;
        box-sizing: border-box;
      }

      .graph-week {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex-shrink: 0;
      }

      .graph-day {
        width: 10px;
        height: 10px;
        border-radius: 0;
        transition: box-shadow 0.2s, transform 0.2s;
      }
      
      .graph-day:hover {
        box-shadow: 0 0 8px currentColor, 0 0 12px currentColor;
        transform: scale(1.2);
        z-index: 10;
        position: relative;
      }

      @keyframes vsShift {
        0% { background-position: 0% 50%; transform: scale(1); filter: drop-shadow(0 0 5px rgba(138, 43, 226, 0.4)); }
        50% { background-position: 100% 50%; transform: scale(1.4); filter: drop-shadow(0 0 15px rgba(207, 34, 46, 0.8)) drop-shadow(0 0 30px rgba(138, 43, 226, 1)); }
        100% { background-position: 0% 50%; transform: scale(1); filter: drop-shadow(0 0 5px rgba(138, 43, 226, 0.4)); }
      }

      .vs-badge {
        font-size: 2rem;
        font-weight: 900;
        padding: 1rem;
        flex-shrink: 0;
        background: linear-gradient(270deg, #cf222e, #8a2be2, #cf222e);
        background-size: 200% 200%;
        color: transparent;
        -webkit-background-clip: text;
        animation: vsShift 1.5s ease-in-out infinite;
      }

      .error {
        color: #cf222e;
        text-shadow: 0 0 5px #cf222e;
      }
      
      @keyframes loadingColorShift {
        0%, 100% { color: #5fed83; text-shadow: 0 0 5px #5fed83; }
        50% { color: #8a2be2; text-shadow: 0 0 5px #8a2be2; }
      }
      
      .loading-text {
        animation: loadingColorShift 1s infinite;
      }
    </style>
  </head>
  <body>
    <h1>Mona Mayhem</h1>
    <h2>GitHub Contribution Battle Arena</h2>
    
    <form id="battle-form">
      <div class="arena">
        <div class="player">
          <label for="player1"><strong>Player 1</strong></label>
          <input type="text" id="player1" name="player1" placeholder="GitHub Username" required />
        </div>
        <div class="player">
          <label for="player2"><strong>Player 2</strong></label>
          <input type="text" id="player2" name="player2" placeholder="GitHub Username" required />
        </div>
      </div>
      <button type="submit">Battle!</button>
    </form>

    <div id="results-area">
      <p>Enter two usernames to start the battle!</p>
    </div>

    <script>
      interface ContributionDay {
        weekday: number;
        count: number;
        level: number;
      }

      interface ContributionWeek {
        index: number;
        first_day: string;
        contribution_days: ContributionDay[];
      }

      interface ContributionsData {
        total_contributions: number;
        from: string;
        to: string;
        colors_full: string[];
        weeks: ContributionWeek[];
        error?: string;
      }

      const form = document.getElementById('battle-form') as HTMLFormElement;
      const resultsArea = document.getElementById('results-area') as HTMLDivElement;

      function renderGraph(data: ContributionsData): string {
        if (!data.weeks) return '';
        let graphHtml = '<div class="graph">';
        for (const week of data.weeks) {
          graphHtml += '<div class="graph-week">';
          
          // Parse the first day of the week
          const firstDayDate = new Date(week.first_day + 'T00:00:00Z');
          
          for (const day of week.contribution_days) {
            const color = data.colors_full[day.level];
            
            // Calculate actual date for tooltip
            const currentDate = new Date(firstDayDate);
            currentDate.setUTCDate(currentDate.getUTCDate() + day.weekday);
            const dateStr = currentDate.toISOString().split('T')[0];
            
            graphHtml += `<div class="graph-day" style="background-color: ${color};" title="${day.count} contributions on ${dateStr}"></div>`;
          }
          graphHtml += '</div>';
        }
        graphHtml += '</div>';
        return graphHtml;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const p1Input = document.getElementById('player1') as HTMLInputElement;
        const p2Input = document.getElementById('player2') as HTMLInputElement;
        
        const p1 = p1Input.value.trim();
        const p2 = p2Input.value.trim();
        
        if (!p1 || !p2) {
          resultsArea.innerHTML = '<p class="error">Both usernames are required.</p>';
          return;
        }
        
        resultsArea.innerHTML = '<p class="loading-text">Let the battle begin... fetching data...</p>';

        try {
          const [res1, res2] = await Promise.all([
            fetch(`/api/contributions/${p1}`),
            fetch(`/api/contributions/${p2}`)
          ]);

          const data1: ContributionsData = await res1.json();
          const data2: ContributionsData = await res2.json();

          if (!res1.ok || !res2.ok || data1.error || data2.error) {
            const error1 = data1.error ? `<p class="error">${p1}: ${data1.error}</p>` : '';
            const error2 = data2.error ? `<p class="error">${p2}: ${data2.error}</p>` : '';
            resultsArea.innerHTML = `
              ${error1}
              ${error2}
            `;
            return;
          }

          const score1 = data1.total_contributions || 0;
          const score2 = data2.total_contributions || 0;

          let winnerText = "It's a Tie!";
          if (score1 > score2) winnerText = `${p1} Wins!`;
          if (score2 > score1) winnerText = `${p2} Wins!`;

          resultsArea.innerHTML = `
            <h3>${winnerText}</h3>
            <div class="results-grid">
              <div class="player-result graph-container">
                <h4>${p1}</h4>
                <p class="player-score">${score1} contribs</p>
                <p class="player-dates">${data1.from} to ${data1.to}</p>
                ${renderGraph(data1)}
              </div>
              <div class="vs-badge">VS</div>
              <div class="player-result graph-container">
                <h4>${p2}</h4>
                <p class="player-score">${score2} contribs</p>
                <p class="player-dates">${data2.from} to ${data2.to}</p>
                ${renderGraph(data2)}
              </div>
            </div>
          `;
        } catch (err) {
          resultsArea.innerHTML = `<p class="error">Network error: ${err instanceof Error ? err.message : 'Unknown error'}</p>`;
        }
      });
    </script>
  </body>
</html>
